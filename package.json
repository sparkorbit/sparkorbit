{
  "name": "sparkorbit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "python3 -m backend.app api-server",
    "build": "tsc -b && vite build",
    "docker:up": "bash scripts/docker-up.sh",
    "docker:up:llm": "bash scripts/docker-up.sh --with-llm",
    "docker:up:no-llm": "bash scripts/docker-up.sh --without-llm",
    "docker:update": "bash scripts/docker-update.sh",
    "docker:down": "bash scripts/docker-down.sh",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:repeat": "playwright test --repeat-each=3"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.58.2",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "8.0.1"
  }
}
