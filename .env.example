# ─── Redis ───────────────────────────────────────────────
SPARKORBIT_REDIS_URL=redis://127.0.0.1:6380/0
SPARKORBIT_REDIS_BIND_HOST=127.0.0.1
SPARKORBIT_REDIS_HOST_PORT=6380

# ─── Published ports ─────────────────────────────────────
# Frontend is public by default so the dashboard can be opened from another
# machine through the server IP (for example http://10.20.23.60:3000).
SPARKORBIT_FRONTEND_BIND_HOST=0.0.0.0
# Keep backend/Ollama local unless you explicitly need direct API access.
SPARKORBIT_BACKEND_BIND_HOST=127.0.0.1
SPARKORBIT_OLLAMA_BIND_HOST=127.0.0.1

# ─── Session ─────────────────────────────────────────────
# Number of sessions to keep (active + previous). Min: 1
SPARKORBIT_SESSION_RETAIN_COUNT=2

# ─── Summary / Briefing provider ─────────────────────────
# Summary: "noop" (default) | "heuristic"
SPARKORBIT_SUMMARY_PROVIDER=noop
# Briefing: "off" (default) | "ollama"
SPARKORBIT_BRIEFING_PROVIDER=off

# ─── Ollama (local LLM) ─────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TIMEOUT=60
OLLAMA_NUM_CTX=131072
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.8
OLLAMA_TOP_K=20
OLLAMA_KEEP_ALIVE=30m
SPARKORBIT_OLLAMA_HOST_PORT=11434

# ─── LLM chunking ───────────────────────────────────────
SPARKORBIT_LLM_COMPANY_CHUNK_SIZE=48
SPARKORBIT_LLM_COMPANY_PER_SOURCE=8
SPARKORBIT_LLM_COMPANY_MAX_AGE_DAYS=90
SPARKORBIT_LLM_PAPER_CHUNK_SIZE=100

# ─── LLM readiness ──────────────────────────────────────
SPARKORBIT_LLM_READY_TIMEOUT=900
SPARKORBIT_LLM_READY_POLL_INTERVAL=5

# ─── Worker ──────────────────────────────────────────────
SPARKORBIT_WORKER_POLL_INTERVAL=2
